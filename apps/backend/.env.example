# Servidor
NODE_ENV=development
PORT=3000

# Base de datos (Aiven o local)
DATABASE_URL=postgresql://usuario:password@host:5432/focusboard

# Redis - Upstash
REDIS_URL=rediss://default:tu_redis_token@tu_host.upstash.io:6379

# JWT (generar con: openssl rand -hex 32)
ACCESS_TOKEN_SECRET=generar_con_openssl_rand_hex_32_minimo_64_chars
REFRESH_TOKEN_SECRET=generar_con_openssl_rand_hex_32_distinto_al_anterior

# CORS
CORS_ORIGIN=http://localhost:5173

# Cron (string aleatorio para proteger endpoint cron)
CRON_SECRET=tu_cron_secret_aleatorio
