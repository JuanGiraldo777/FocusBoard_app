{
  "name": "@focusboard/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --watch src/index.ts",
    "build": "tsc",
    "lint": "eslint src",
    "migrate:up": "node-pg-migrate up --migrations-dir src/migrations --database-url-var DATABASE_URL",
    "migrate:down": "node-pg-migrate down --migrations-dir src/migrations --database-url-var DATABASE_URL"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "node-pg-migrate": "^8.0.4",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3",
    "redis": "^5.12.1",
    "@socket.io/redis-adapter": "^8.1.0",
    "cookie": "^0.5.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6",
     "@focusboard/shared": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",    
    "eslint": "^9.39.4",
    "typescript-eslint": "^8.46.2"
  }
}
